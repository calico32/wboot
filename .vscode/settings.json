{
    "biome.enabled": false,
    "explorer.autoRevealExclude": {
        "gnu-efi": true,
        "linux": true
    },
    "files.exclude": {
        "src/**/*.o": true
    },
    "mesonbuild.configureOnOpen": false,
    "git.autoRepositoryDetection": false,
    "files.readonlyInclude": {
        "vendor/gnu-efi/**/*": true,
        "vendor/edk2/**/*": true,
        "vendor/linux/**/*": true
    },
    "tinymist.fontPaths": ["${workspaceFolder}/presentation/fonts"],
    "tinymist.formatterIndentSize": 4,
    "tinymist.systemFonts": false
}
